
# Bobke m13 case

DEFINE XIN 200
DEFINE XOUT 2500

DEFINE YTOP 120

DEFINE LZ 120

# delta99_in 8.2888
# delta99_out 84.1314

DEFINE DELTA 8.0

PART SURF BOX X0 $(XIN) 0 0 X1 $(XOUT) $(YTOP) $(LZ) PERIODIC_Z

HCP_DELTA $(DELTA)

HCP_WINDOW FAZONE Y0 LEVEL 3 NLAYERS 10

NSMOOTH 20

WRITE_MLES grid.mles

WRITE_IMAGE NAME xm GEOM X_PLANE_FRAC 0.5 VAR 3d_mesh
WRITE_IMAGE NAME zm GEOM Z_PLANE_FRAC 0.5 VAR 3d_mesh

