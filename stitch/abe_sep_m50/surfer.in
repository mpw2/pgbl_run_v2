
DEFINE LX 400
DEFINE LY 80
DEFINE LZ 160

DEFINE PRE 50
DEFINE EXT 200

SURF BOX (-$(PRE)) ($(LX)+$(EXT)) 0 $(LY) 0 $(LZ)

IMPRINT PLANE 0 0 0 -1 0 0 ZONES y0 SPLIT_ZONES
MOVE_TO_ZONE NAME y0_zpg ZONES y0_split
IMPRINT PLANE $(LX) 0 0 1 0 0 ZONES y0 SPLIT_ZONES

SET_PERIODIC ZONES z0 z1 CART 0 0 $(LZ)

WRITE_SBIN domain.sbin

RUN_DIAGNOSTICS

